{
  "name": "ecommerce-mern",
  "version": "1.0.0",
  "description": "Full-stack MERN e-commerce application",
  "scripts": {
    "build": "npm i --prefix frontend && npm run build --prefix frontend",
    "install-all": "npm i && npm i --prefix backend && npm i --prefix frontend",
    "backend": "npm run dev --prefix backend",
    "frontend": "npm run dev --prefix frontend",
    "dev": "concurrently \"npm run backend\" \"npm run frontend\"",
    "seed": "npm run seed --prefix backend"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "cloudinary": "^2.2.0",
    "concurrently": "^8.2.2",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.2",
    "morgan": "^1.10.0",
    "multer": "^1.4.5-lts.1",
    "pg": "^8.22.0",
    "razorpay": "^2.9.4",
    "stripe": "^15.11.0"
  }
}
